---
import Layout from '../layouts/Layout.astro';

interface Props {
	title: string;
	description: string;
	path: string;
}

const { title, description, path } = Astro.props;
const canonical = `https://www.resdat.es${path}`;
---

<Layout title={`${title} | Resdat`} description={description} canonical={canonical}>
	<a href="#contenido-legal" class="skip-link">Ir al contenido</a>
	<header class="border-b border-mist bg-surface/90 backdrop-blur-sm">
		<div
			class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8"
		>
			<a
				href="/"
				class="text-sm font-semibold text-ink underline decoration-mist underline-offset-4 transition-colors hover:text-accent hover:decoration-accent"
			>
				← Volver al inicio
			</a>
			<span class="font-display text-xs font-bold uppercase tracking-widest text-muted"
				>Resdat</span
			>
		</div>
	</header>
	<main id="contenido-legal" class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
		<h1 class="font-display text-3xl font-bold tracking-tight text-ink">{title}</h1>
		<p class="mt-2 text-sm text-muted">Última actualización: mayo de 2026</p>
		<div class="legal-doc mt-10 space-y-4">
			<slot />
		</div>
	</main>
	<footer class="border-t border-mist bg-paper py-8">
		<div class="mx-auto flex max-w-3xl flex-wrap justify-between gap-4 px-4 text-sm text-muted sm:px-6 lg:px-8">
			<a href="/" class="font-medium text-ink hover:text-accent">Inicio</a>
			<div class="flex gap-6">
				<a href="/aviso-legal" class="hover:text-ink">Aviso legal</a>
				<a href="/politica-privacidad" class="hover:text-ink">Privacidad</a>
			</div>
		</div>
	</footer>
</Layout>
