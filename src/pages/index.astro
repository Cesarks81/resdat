			<div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
				<div class="grid gap-12 lg:grid-cols-2 lg:gap-20">
					<div>
						<p class="font-mono text-xs font-medium uppercase tracking-widest text-muted">
							08 · Contacto
						</p>
						<h2 class="mt-3 font-display text-2xl font-semibold tracking-tight text-ink sm:text-3xl">
							¿Reto digital en marcha?
						</h2>
						<p class="mt-4 text-muted">
							Cuéntanos en unas líneas. Te respondemos con siguientes pasos o una propuesta de
							diagnóstico.
						</p>
						<div class="mt-8 space-y-3 border-l-2 border-accent pl-5 text-sm text-muted">
							<p>
								<span class="font-medium text-ink">Email:</span>{' '}
								<a
									href="mailto:cesarks81@gmail.com"
									class="text-accent underline decoration-accent/30 underline-offset-2 hover:decoration-accent"
								>
									cesarks81@gmail.com
								</a>
							</p>
							<p>
								<span class="font-medium text-ink">Tel. / WhatsApp:</span>{' '}
								<a
									href="https://wa.me/34689932175"
									class="text-accent underline decoration-accent/30 underline-offset-2 hover:decoration-accent"
								>
									+34 689 932 175
								</a>
							</p>
							<p>
								<span class="font-medium text-ink">Ubicación:</span> León, España · remoto en
								todo el país
							</p>
						</div>
					</div>
					<div class="border border-mist bg-paper/50 p-6 sm:p-8">
						<form action={CONTACT_FORM_ACTION} method="POST" class="space-y-5">
							<input type="hidden" name="_subject" value="Contacto web resdat.es" />
							<div>
								<label for="nombre" class="block text-sm font-medium text-ink">Nombre</label>
								<input
									id="nombre"
									name="nombre"
									type="text"
									required
									autocomplete="name"
									class="mt-1.5 w-full rounded-sm border border-mist bg-surface px-3 py-2.5 text-sm text-ink outline-none transition-shadow focus:border-accent focus:ring-2 focus:ring-accent/20"
								/>
							</div>
							<div>
								<label for="empresa" class="block text-sm font-medium text-ink">Empresa</label>
								<input
									id="empresa"
									name="empresa"
									type="text"
									required
									autocomplete="organization"
									class="mt-1.5 w-full rounded-sm border border-mist bg-surface px-3 py-2.5 text-sm text-ink outline-none focus:border-accent focus:ring-2 focus:ring-accent/20"
								/>
							</div>
							<div>
								<label for="email" class="block text-sm font-medium text-ink">Email</label>
								<input
									id="email"
									name="email"
									type="email"
									required
									autocomplete="email"
									class="mt-1.5 w-full rounded-sm border border-mist bg-surface px-3 py-2.5 text-sm text-ink outline-none focus:border-accent focus:ring-2 focus:ring-accent/20"
								/>
							</div>
							<div>
								<label for="telefono" class="block text-sm font-medium text-ink"
									>Teléfono <span class="font-normal text-muted">(opcional)</span></label
								>
								<input
									id="telefono"
									name="telefono"
									type="tel"
									autocomplete="tel"
									class="mt-1.5 w-full rounded-sm border border-mist bg-surface px-3 py-2.5 text-sm text-ink outline-none focus:border-accent focus:ring-2 focus:ring-accent/20"
								/>
							</div>
							<div>
								<label for="mensaje" class="block text-sm font-medium text-ink"
									>¿Qué necesitáis?</label
								>
								<textarea
									id="mensaje"
									name="mensaje"
									rows="4"
									required
									class="mt-1.5 w-full resize-y rounded-sm border border-mist bg-surface px-3 py-2.5 text-sm text-ink outline-none focus:border-accent focus:ring-2 focus:ring-accent/20"
								></textarea>
							</div>
							<button
								type="submit"
								class="w-full rounded-sm bg-accent px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-hover sm:w-auto"
							>
								Enviar solicitud
							</button>
						</form>
					</div>
				</div>
			</div>
		</section>
	</main>

	<footer class="border-t border-mist bg-ink py-12 text-paper">
		<div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
			<div class="flex flex-col gap-8 lg:flex-row lg:items-start lg:justify-between">
				<div>
					<p class="font-display text-lg font-extrabold tracking-wide text-paper">RESDAT</p>
					<p class="mt-2 max-w-xs text-sm text-paper/60">
						Soluciones digitales que impulsan tu empresa.
					</p>
				</div>
				<div class="flex flex-wrap gap-x-8 gap-y-3 text-sm text-paper/70">
					<a href="#" class="transition-colors hover:text-paper">Aviso legal</a>
					<a href="#" class="transition-colors hover:text-paper">Privacidad</a>
					<a
						href="https://www.resdat.es/"
						class="transition-colors hover:text-paper"
					>
						resdat.es
					</a>
				</div>
			</div>
			<p class="mt-10 border-t border-paper/10 pt-8 text-xs text-paper/45">
				© {new Date().getFullYear()} RESDAT. Todos los derechos reservados.
			</p>
		</div>
	</footer>
</Layout>

<style>
	.skip-link {
		position: absolute;
		left: 1rem;
		top: 1rem;
		z-index: 50;
		padding: 0.5rem 1rem;
		border-radius: 2px;
		background: var(--color-surface);
		box-shadow:
			0 1px 3px 0 rgb(0 0 0 / 0.12),
			0 1px 2px -1px rgb(0 0 0 / 0.1);
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--color-ink);
		transform: translateY(-130%);
		transition: transform 0.15s ease;
	}
	.skip-link:focus {
		transform: translateY(0);
		outline: 2px solid var(--color-accent);
		outline-offset: 2px;
